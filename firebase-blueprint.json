{
  "entities": {
    "provenance_record": {
      "title": "Provenance Record",
      "description": "Minted record of sports media authenticity and ownership",
      "type": "object",
      "properties": {
        "mediaTitle": { "type": "string", "description": "Title of the sports event or clip" },
        "ownerId": { "type": "string", "description": "UID of the owning organization" },
        "ownerName": { "type": "string", "description": "Display name of the owner (e.g. NBA)" },
        "blockchainTx": { "type": "string", "description": "Transaction hash on the digital ledger" },
        "authenticityScore": { "type": "number", "description": "AI-calculated integrity score (0-100)" },
        "status": { "type": "string", "enum": ["MINTED", "VERIFIED", "PENDING"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["Clip", "Stream", "Live", "Replay"] },
        "duration": { "type": "string" }
      },
      "required": ["mediaTitle", "ownerId", "blockchainTx", "status", "createdAt"]
    },
    "piracy_alert": {
      "title": "Piracy Alert",
      "description": "Detection of illegal redistribution of sporting media",
      "type": "object",
      "properties": {
        "alertId": { "type": "string" },
        "source": { "type": "string", "description": "Platform where piracy was detected" },
        "match": { "type": "string" },
        "severity": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "status": { "type": "string", "enum": ["Blocked", "Notified", "Redirecting", "Active"] },
        "detectedAt": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "ipAddress": { "type": "string" }
      },
      "required": ["source", "match", "severity", "status", "detectedAt"]
    }
  },
  "firestore": {
    "/provenance_records/{recordId}": {
      "schema": "provenance_record",
      "description": "Collection of all minted provenance records"
    },
    "/piracy_alerts/{alertId}": {
      "schema": "piracy_alert",
      "description": "Real-time feed of detected piracy incidents"
    }
  }
}
